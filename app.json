{
  "expo": {
    "name": "Nirvah Care Doctor",
    "slug": "doctorsdesksapp",
    "plugins": [
      "expo-router",
      "expo-notifications"
    ],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/logo.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "jsEngine": "jsc",
    "splash": {
      "image": "./assets/images/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#fcfcfc"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.doctorsdesks.doctorsdesksapp"
    },
    "android": {
      "package": "com.doctorsdesks.doctorsdesksapp",
      "googleServicesFile": "./google-services.json",
      "usesCleartextTraffic": true,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logo.png",
        "backgroundColor": "#fcfcfc",
        "monochromeImage": "./assets/images/logo.png"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/logo.png"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "dcf2fb39-f394-4bb0-8d68-502913a234db"
      }
    },
    "owner": "doctorsdesks"
  }
}
